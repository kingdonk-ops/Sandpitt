{
  "realm": "sandpitt",
  "enabled": true,
  "displayName": "Sandpitt Inspection System",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "clients": [
    {
      "clientId": "sandpitt-api",
      "name": "Sandpitt API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme_keycloak_secret",
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "sandpitt-admin",
      "name": "Sandpitt Admin UI",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true
    },
    {
      "clientId": "sandpitt-mobile",
      "name": "Sandpitt Mobile App",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["sandpitt://auth/*", "exp://localhost:8081/*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {"name": "admin", "description": "System administrator"},
      {"name": "supervisor", "description": "Inspection supervisor"},
      {"name": "inspector", "description": "Field inspector"}
    ]
  },
  "users": [
    {
      "username": "admin@sandpitt.local",
      "email": "admin@sandpitt.local",
      "firstName": "System",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Admin1234!", "temporary": false}],
      "realmRoles": ["admin"]
    },
    {
      "username": "inspector@sandpitt.local",
      "email": "inspector@sandpitt.local",
      "firstName": "Test",
      "lastName": "Inspector",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Inspector1234!", "temporary": false}],
      "realmRoles": ["inspector"]
    }
  ]
}
