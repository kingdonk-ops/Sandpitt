# =============================================================================
# Sandpitt Inspection System — Environment Variables
# Copy to .env and fill in values before running docker compose up
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL / PostGIS
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sandpitt
POSTGRES_USER=sandpitt
POSTGRES_PASSWORD=changeme_postgres

# Async connection URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://sandpitt:changeme_postgres@postgres:5432/sandpitt

# -----------------------------------------------------------------------------
# API (FastAPI)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
SECRET_KEY=changeme_super_secret_key_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=sandpitt
KEYCLOAK_CLIENT_ID=sandpitt-api
KEYCLOAK_CLIENT_SECRET=changeme_keycloak_secret
# JWKS endpoint — derived from the above; override if needed
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/sandpitt/protocol/openid-connect/certs

# Admin credentials (used only at first boot)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET_PHOTOS=inspection-photos
MINIO_SECURE=false
# Public base URL for presigned URLs (use http://localhost:9000 in local dev)
MINIO_PUBLIC_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Admin UI (Next.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme_nextauth_secret
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=sandpitt
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=sandpitt-admin

# -----------------------------------------------------------------------------
# Mobile (Expo)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080
EXPO_PUBLIC_KEYCLOAK_REALM=sandpitt
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=sandpitt-mobile

# -----------------------------------------------------------------------------
# Metabase
# -----------------------------------------------------------------------------
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=metabase
MB_DB_PASS=changeme_metabase
MB_DB_HOST=postgres
